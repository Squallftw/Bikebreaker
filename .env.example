# Supabase (Butchapp project → bikebreaker schema).
# Copy this file to `.env.local` and fill in real values for local dev.
# In production these are set as GitHub Actions secrets (see .github/workflows/deploy.yml).
#
# Dashboard → Settings → API:
#   VITE_SUPABASE_URL      = Project URL  (https://<ref>.supabase.co)
#   VITE_SUPABASE_ANON_KEY = anon / public key
#
# Both are safe to expose publicly — the anon key is protected by row-level security.
# If either is missing, the app runs from its bundled fallback catalog.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
